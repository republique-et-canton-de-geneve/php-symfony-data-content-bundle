{
    "name": "republique-et-canton-de-geneve/php-symfony-data-content-bundle",
    "description": "Symfony bundle for GED tessi data content.",
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.0",
        "symfony/dependency-injection": ">=6.4",
        "symfony/http-kernel": ">=6.4",
        "symfony/config": ">=6.4",
        "symfony/mime": ">=6.4",
        "symfony/security-bundle": ">=6.4",
        "symfony/http-client": ">=6.4",
        "symfony/cache": ">=6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "*",
        "phpstan/extension-installer": "*",
        "phpstan/phpstan": "*",
        "friendsofphp/php-cs-fixer": "*",
        "rector/rector": "*",
        "phpunit/php-code-coverage": "*"
    },
    "license": "Apache-2.0",
    "keywords": [
        "bundle",
        "symfony",
        "response",
        "Data Content" ,
        "DataContent",
        "Tessi"
    ],
    "autoload": {
        "psr-4": {
            "EtatGeneve\\DataContentBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EtatGeneve\\DataContentBundle\\Tests\\": "Tests/"
        }
    },
    "authors": [
        {
            "name": "Michel Bobillier aka Athos99",
            "email": "athos99@bluewin.ch",
            "role": "Senior Lead Developer"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
