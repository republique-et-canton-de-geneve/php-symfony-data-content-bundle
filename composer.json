{
    "name": "republique-et-canton-de-geneve/php-data-content-bundle",
    "version": "1.0.0",
    "description": "Symfony bundle for GED tessi data content.",
    "type": "symfony-bundle",
    "require": {
        "php": ">=7.4",
        "symfony/dependency-injection": "^5.4",
        "symfony/http-kernel": "^5.4",
        "symfony/config": "^5.4",
        "symfony/mime": "^5.4",
        "symfony/security-bundle": "^5.4",
        "symfony/http-client": "^5.4",
        "symfony/cache": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.49",
        "rector/rector": "^2.3",
        "phpunit/php-code-coverage": "*"
    },
    "license": "Apache-2.0",
    "keywords": [
        "bundle",
        "symfony",
        "response",
        "Data Content" ,
        "Tessi"
    ],
    "autoload": {
        "psr-4": {
            "EtatGeneve\\DataContentBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EtatGeneve\\DataContentBundle\\Tests\\": "Tests/"
        }
    },
    "authors": [
        {
            "name": "Michel Bobillier aka Athos99",
            "email": "athos99@bluewin.ch",
            "role": "Senior Lead Developer"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
